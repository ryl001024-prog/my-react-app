{
  "compilerOptions": {
    // 编译目标：生成 ES2020 标准的 JavaScript 代码
    // 这样可以使用现代 JS 特性，如可选链(?.)、空值合并(??)等
    "target": "ES2020",
    // 使用标准的类字段定义方式（而不是旧的 TypeScript 实现）
    // 确保类字段的行为与现代 JavaScript 标准一致
    "useDefineForClassFields": true,
    // 包含的类型定义库：
    // - ES2020: 现代 JavaScript 特性类型
    // - DOM: 浏览器 DOM API 类型
    // - DOM.Iterable: 可迭代的 DOM 集合类型
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    // 模块系统：使用 ESNext（最新的 ES 模块标准）
    // 这样可以使用动态 import() 等现代模块特性
    "module": "ESNext",
    // 跳过库文件的类型检查，加快编译速度
    // 对于 node_modules 中的第三方库不进行严格类型检查
    "skipLibCheck": true,
    // 模块解析策略：使用与现代化打包工具兼容的方式
    // 针对 Vite、Webpack 等工具的模块解析优化
    "moduleResolution": "bundler",
    // 允许在 import 语句中使用 TypeScript 扩展名（.ts、.tsx）
    // 例如：import './file.ts' 而不是 import './file'
    "allowImportingTsExtensions": true,
    // 允许导入 JSON 文件作为模块
    // 例如：import package from './package.json'
    "resolveJsonModule": true,
    // 确保每个文件都可以独立编译，不依赖其他文件
    // 这是 Vite 等工具的要求，用于快速热更新
    "isolatedModules": true,
    // TypeScript 只进行类型检查，不输出编译后的文件
    // 因为 Vite 会负责实际的编译打包工作
    "noEmit": true,
    // JSX 转换模式：使用 React 17+ 的新 JSX 转换
    // 自动从 'react/jsx-runtime' 导入 JSX 函数，无需手动导入 React
    "jsx": "react-jsx",
    // 启用所有严格类型检查选项
    // 包括：noImplicitAny、strictNullChecks、strictFunctionTypes 等
    "strict": true,
    // 报告未使用的局部变量错误
    // 帮助保持代码清洁，避免无用的变量声明
    "noUnusedLocals": true,
    // 报告未使用的函数参数错误
    // 提醒清理不必要的函数参数
    "noUnusedParameters": true,
    // 强制 switch 语句中必须有 break 或 return，防止 case 穿透
    // 避免常见的逻辑错误
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "checkJs": false,
    // 专门针对 React 19 实验性特性的类型定义
    // 确保 TypeScript 能正确理解 React 19 的新 API 和类型
    "types": ["react/experimental", "react-dom/experimental"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.jsx",
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.cjs",
    "src/**/*.less",
    "src/**/*.css"
  ],
  "exclude": [
    "node_modules" // 排除的文件
  ]
}
